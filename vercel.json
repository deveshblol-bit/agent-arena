{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/board",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "env": {
    "RPC_URL": "https://sepolia.base.org",
    "ESCROW_ADDRESS": "0x5AE674C0CFBD27514716E2b27C3E22339Cb80bDF"
  }
}
